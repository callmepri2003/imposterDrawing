{
  "name": "imposter-drawing-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.4.0",
    "autoprefixer": "^10.4.19",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.6",
    "vitest": "^1.4.0"
  },
  "vitest": {
    "environment": "jsdom",
    "setupFiles": ["./src/__tests__/setup.js"],
    "coverage": {
      "provider": "v8",
      "thresholds": {
        "lines": 75,
        "functions": 75,
        "branches": 65,
        "statements": 75
      },
      "exclude": ["node_modules/", "src/__tests__/", "src/main.jsx", "vite.config.js"]
    }
  }
}
